{
    "name": "hadimakki47/theatre-booking-system",
    "description": "Theatre seat booking platform with transactional bookings, coupons, admin panel, and live support chat",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-mysqli": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration"
    },
    "config": {
        "sort-packages": true
    }
}
